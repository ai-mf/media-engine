FROM rust:1.70 AS builder
WORKDIR /app
COPY . .
RUN cargo build --release --bin aimf-server

FROM debian:bookworm-slim
RUN apt-get update && apt-get install -y ca-certificates ffmpeg && rm -rf /var/lib/apt/lists/*
COPY --from=builder /app/target/release/aimf-server /usr/local/bin/
EXPOSE 8080
CMD ["aimf-server"]